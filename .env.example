NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2023-05-03
SANITY_API_TOKEN=
REVALIDATE_SECRET=
SITE_BASE_URL=https://www.usa-graphene.com

# Image provider for blog covers
IMAGE_PROVIDER=google
OPENAI_IMAGE_MODEL=gpt-image-1

# Google image generation for blog covers
# Use Google's Pro image model for blog covers.
GEMINI_IMAGE_MODEL=nano-banana-pro-preview
GEMINI_IMAGE_FALLBACK_MODEL=gemini-3.1-flash-image
# Options: cover or infographic
GEMINI_IMAGE_STYLE=infographic

# Optional LinkedIn company page reposting
# Page: https://www.linkedin.com/company/104011167/
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=104011167
LINKEDIN_VERSION=202602

# Carbon chatbot backend
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local/Postgres knowledge base
DATABASE_URL=postgresql://graphene_app:graphene_local_2026@localhost:5432/graphene_kb

# Optional future hosted database
# DATABASE_URL=
